# Database connection settings for Mattermost and postgres_exporter
# Update these to match your local PostgreSQL setup

# PostgreSQL connection for Mattermost
DB_USER=mattermost
DB_PASSWORD=mattermost
DB_NAME=mattermost
DB_PORT=5432

# Note: The connection uses host.docker.internal to reach your local PostgreSQL
# If your PostgreSQL is running on a different host, update the docker-compose.yml
